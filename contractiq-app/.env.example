# ============================================================================
# ContractIQ — Environment Variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=              # Supabase project URL — Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Supabase anon/public key — Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=             # SERVER ONLY — Project Settings > API. Never expose to the browser or prefix with NEXT_PUBLIC_.

# OpenAI
OPENAI_API_KEY=                        # SERVER ONLY — platform.openai.com/api-keys. Used for GPT-4o key-term extraction and contract chat.

# App
NEXT_PUBLIC_APP_URL=                   # Full deployed app URL (e.g. http://localhost:3000 in dev, https://app.contractiq.com in prod) — used for Supabase Auth redirects

# Security
MAX_CHAT_HISTORY=100                   # Max prior chat messages sent to the model as context per request
